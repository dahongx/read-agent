# ── 运行模式 ──────────────────────────────────────────────
DEV_MODE=false
DEV_MODE_RAG=false

# ── 目录配置 ──────────────────────────────────────────────
UPLOAD_DIR=backend/uploads
PPT_CACHE_DIR=backend/uploads/ppt_cache

# paper-to-ppt skill 目录。推荐使用项目相对路径。
SKILL_DIR=.claude/skills/paper-to-ppt

# Claude CLI 可执行文件路径；如果 claude 已在 PATH 中，可留空
CLAUDE_CLI_PATH=

# Windows 下可选：如果 Claude CLI 需要显式指定 Git Bash，则填写路径
GIT_BASH_PATH=

# ── LLM 配置（智谱AI GLM，也可换成其他 OpenAI 兼容接口）──
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4-flash

# Local embedding model configuration
EMBED_MODEL_NAME=BAAI/bge-m3
EMBED_MODEL_DIR=backend/models/bge-m3
EMBED_CACHE_DIR=backend/models/cache
